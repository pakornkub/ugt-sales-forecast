# Optional AI integration.
GEMINI_API_KEY=""

# Microsoft SQL Server connection used by Prisma.
# Format: sqlserver://HOST:1433;database=DB_NAME;user=USER;password=PASSWORD;encrypt=true;trustServerCertificate=true
DATABASE_URL="sqlserver://HOST:1433;database=DB_NAME;user=USER;password=YOUR_PASSWORD;encrypt=true;trustServerCertificate=true"

# Express server and public application location.
API_PORT=3001
HOST_PORT=3000
APP_BASE_PATH=/ugt-sales-forecast
APP_BASE_URL=https://ugtweb.ube.co.th

# Production authentication. Never enable DEV_AUTH_BYPASS in production.
DEV_AUTH_BYPASS=false
SESSION_SECRET="replace-with-at-least-32-random-characters"

# Keycloak OIDC configuration for realm ugt.
KEYCLOAK_ISSUER="https://ugtweb.ube.co.th/keycloak/realms/ugt"
KEYCLOAK_CLIENT_ID="ugt-sales-forecast"
# Set only when the Keycloak client is confidential. Keep server-side only.
KEYCLOAK_CLIENT_SECRET=""

# Read Registration and Actual data from the local performance snapshot.
USE_LOCAL_SNAPSHOT=true
