generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// App-owned tables  (migrations managed by this app)
// ─────────────────────────────────────────────────────────────────────────────

/// Forecast versions (e.g. "Current Forecast", "BB FY26", "SepF FY26")
model ForecastVersion {
  name       String          @id @db.NVarChar(100)
  versionKey Int             @default(0)
  isStandard Boolean         @default(false)
  createdAt  DateTime        @default(now())
  values     ForecastValue[]

  @@unique([versionKey])
  @@map("forecast_versions")
}

/// Forecast input values (app-owned, written by users)
/// period field stores:
///   - Month granularity: first day of month (DATE) e.g. 2026-06-01
///   - Week  granularity: week anchor date (DATE) e.g. 2026-06-04
model ForecastValue {
  registrationId String          @db.NVarChar(200)
  versionName    String          @db.NVarChar(100)
  period         DateTime        @db.Date
  granularity    String          @db.NVarChar(10)   // "month" or "week"
  qtyFcst        Decimal         @default(0) @db.Decimal(18, 4)
  priceFcst      Decimal         @default(0) @db.Decimal(18, 4)
  amountFcst     Decimal         @default(0) @db.Decimal(18, 4)
  lastBatchId    String?         @db.NVarChar(36)
  updatedAt      DateTime        @default(now()) @updatedAt

  version        ForecastVersion @relation(fields: [versionName], references: [name])

  @@id([registrationId, versionName, period])
  @@map("forecast_values")
}

model ForecastCommitBatch {
  id          String              @id @default(uuid()) @db.NVarChar(36)
  source      String              @db.NVarChar(50)
  changedBy   String              @db.NVarChar(100)
  stampPeriod String              @default("No") @db.NVarChar(30)
  recordCount Int                 @default(0)
  createdAt   DateTime            @default(now())
  changes     ForecastChangeLog[]

  @@map("forecast_commit_batches")
}

model ForecastChangeLog {
  id             String              @id @default(uuid()) @db.NVarChar(36)
  batchId        String              @db.NVarChar(36)
  registrationId String              @db.NVarChar(200)
  versionName    String              @db.NVarChar(100)
  period         DateTime            @db.Date
  granularity    String              @db.NVarChar(10)
  oldQtyFcst     Decimal?            @db.Decimal(18, 4)
  newQtyFcst     Decimal             @db.Decimal(18, 4)
  oldPriceFcst   Decimal?            @db.Decimal(18, 4)
  newPriceFcst   Decimal             @db.Decimal(18, 4)
  oldAmountFcst  Decimal?            @db.Decimal(18, 4)
  newAmountFcst  Decimal             @default(0) @db.Decimal(18, 4)
  changedAt      DateTime            @default(now())
  batch          ForecastCommitBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([registrationId, versionName, period])
  @@index([batchId])
  @@map("forecast_change_logs")
}

/// @deprecated Legacy table — app uses price_management_values. Kept for DB compatibility only.
model CplPrice {
  month     String  @id @db.NVarChar(7)  // "YYYY-MM"
  price     Decimal @default(0) @db.Decimal(18, 4)

  @@map("cpl_prices")
}

model PriceManagementValue {
  month        String   @db.NVarChar(7)
  priceType    String   @db.NVarChar(10)
  versionName  String   @db.NVarChar(100)
  cplPrice     Decimal  @default(0) @db.Decimal(18, 4)
  naphthaPrice Decimal  @default(0) @db.Decimal(18, 4)
  benzenePrice Decimal  @default(0) @db.Decimal(18, 4)
  updatedAt    DateTime @default(now()) @updatedAt

  @@id([month, priceType, versionName])
  @@index([priceType, versionName, month])
  @@map("price_management_values")
}

/// Per-registration spread override for CRM registration IDs (and optional override layer).
/// Stored as text so formula notes can be kept; numeric-only values are parsed for price math.
model RegistrationPriceSetting {
  registrationId String   @id @db.NVarChar(200)
  spread         String?  @db.NVarChar(1000)
  updatedAt      DateTime @default(now()) @updatedAt
  updatedBy      String?  @db.NVarChar(200)

  @@map("registration_price_settings")
}

/// Registrations created inside Sales Forecast. CRM remains read-only.
model MasterDataCrmRegistration {
  id                          String   @id @default(uuid()) @db.NVarChar(36)
  newKey                      String   @unique @db.NVarChar(1000)
  keyForNoCRM                 String   @unique @db.NVarChar(500)
  mainRegist                  Int      @default(1)
  registrationTopic           String   @db.NVarChar(500)
  soldToCode                  String   @db.NVarChar(100)
  shipToCode                  String   @db.NVarChar(100)
  endUserCode                 String   @db.NVarChar(100)
  plantCode                   String   @db.NVarChar(100)
  materialCode                String   @db.NVarChar(100)
  onOffSpec                   String   @db.NVarChar(20)
  materialDescription         String   @db.NVarChar(500)
  ownerName                   String   @db.NVarChar(500)
  businessUnit                String   @default("Composite") @db.NVarChar(50)
  countryName                 String?  @db.NVarChar(500)
  shipToName                  String?  @db.NVarChar(500)
  soldToName                  String?  @db.NVarChar(500)
  endUser                     String?  @db.NVarChar(500)
  groupName                   String?  @db.NVarChar(500)
  materialNameOnCoa           String?  @db.NVarChar(500)
  additionalRequirement       String?  @db.NVarChar(1000)
  pic                         String?  @db.NVarChar(500)
  commission                  Decimal  @default(0) @db.Decimal(18, 4)
  productDescription          String?  @db.NVarChar(1000)
  classified                  String?  @db.NVarChar(500)
  commissionIndirect          Decimal  @default(0) @db.Decimal(18, 4)
  commissionFinancialDiscount Decimal  @default(0) @db.Decimal(18, 4)
  newCoaName                  String?  @db.NVarChar(500)
  newTier1                    String?  @db.NVarChar(500)
  newOem                      String?  @db.NVarChar(500)
  packing                     String?  @db.NVarChar(500)
  agreedSpecType              String?  @db.NVarChar(500)
  wasteScrap                  String?  @db.NVarChar(500)
  forResaleNotApprove         String?  @db.NVarChar(500)
  imdsDate                    String?  @db.NVarChar(100)
  model                       String?  @db.NVarChar(500)
  approve                     String?  @db.NVarChar(500)
  partName                    String?  @db.NVarChar(500)
  coaName                     String?  @db.NVarChar(500)
  process                     String?  @db.NVarChar(500)
  application                 String?  @db.NVarChar(500)
  subApp                      String?  @db.NVarChar(500)
  zoneName                    String?  @db.NVarChar(500)
  plantName                   String?  @db.NVarChar(500)
  countryCode                 String?  @db.NVarChar(100)
  endUserExportControl        String?  @db.NVarChar(500)
  endUserName                 String?  @db.NVarChar(500)
  productName                 String?  @db.NVarChar(500)
  productNamePud              String?  @db.NVarChar(500)
  gradeUfa                    String?  @db.NVarChar(500)
  gradeSap                    String?  @db.NVarChar(500)
  priceFormula                String   @default("CPL") @db.NVarChar(50)
  spread                      String?  @db.NVarChar(1000)
  createdBy                   String   @default("sales-forecast-web") @db.NVarChar(100)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @default(now()) @updatedAt

  @@map("master_data_crm_registrations")
}

model DataSnapshotState {
  source        String    @id @db.NVarChar(50)
  activeVersion String?   @db.NVarChar(36)
  status        String    @default("idle") @db.NVarChar(20)
  startedAt     DateTime?
  completedAt   DateTime?
  lastError     String?   @db.NVarChar(2000)
  rowCount      Int       @default(0)

  @@map("data_snapshot_state")
}

model OverplanConfig {
  id                    String   @id @default("default") @db.NVarChar(20)
  planVersionName       String   @default("BB FY26") @db.NVarChar(100)
  actualVsPlanEnabled   Boolean  @default(true)
  forecastVsPlanEnabled Boolean  @default(false)
  compareLeft           String   @default("Actual") @db.NVarChar(100)
  compareRight          String   @default("Current Forecast") @db.NVarChar(100)
  aboveEnabled          Boolean  @default(true)
  belowEnabled          Boolean  @default(true)
  aboveThresholdTon     Decimal? @db.Decimal(18, 4)
  aboveThresholdPercent Decimal? @db.Decimal(8, 4)
  belowThresholdTon     Decimal? @db.Decimal(18, 4)
  belowThresholdPercent Decimal? @db.Decimal(8, 4)
  updatedBy             String   @default("system") @db.NVarChar(100)
  updatedAt             DateTime @default(now()) @updatedAt

  @@map("overplan_config")
}

model OverplanRecipient {
  id          String  @id @default(uuid()) @db.NVarChar(36)
  reportType  String  @db.NVarChar(30)
  email       String  @db.NVarChar(320)
  displayName String? @db.NVarChar(200)
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  @@index([reportType, isActive])
  @@map("overplan_recipients")
}

/// Local snapshot of dbo.vwHR_SC_Employee for fast employee search and email lookup.
model HrEmployeeCache {
  empCode       String   @id @db.NVarChar(50)
  fullNameEng   String   @default("") @db.NVarChar(200)
  currentEmail  String   @default("") @db.NVarChar(320)
  costCenterEng String   @default("") @db.NVarChar(300)
  adLoginName   String   @default("") @db.NVarChar(200)
  syncedAt      DateTime @default(now()) @updatedAt

  @@index([fullNameEng])
  @@index([costCenterEng])
  @@map("hr_employee_cache")
}

/// Local snapshot of SAP VW_Customer_master for sold-to / ship-to / end-user name lookup.
model CustomerMasterCache {
  custCode      String   @id @db.NVarChar(50)
  customerName  String   @default("") @db.NVarChar(500)
  syncedAt      DateTime @default(now()) @updatedAt

  @@index([customerName])
  @@map("customer_master_cache")
}

/// Global CC list (not bound to owner) for forecast change emails.
model ForecastCcRecipient {
  id            String  @id @default(uuid()) @db.NVarChar(36)
  empCode       String  @unique @db.NVarChar(50)
  fullNameEng   String  @default("") @db.NVarChar(200)
  currentEmail  String  @default("") @db.NVarChar(320)
  notifyEnabled Boolean @default(false)
  source        String  @default("manual") @db.NVarChar(20)
  sortOrder     Int     @default(0)

  @@map("forecast_cc_recipients")
}

/// Audit of forecast change emails actually sent (per recipient).
model ForecastNotificationSendLog {
  id            String   @id @default(uuid()) @db.NVarChar(36)
  empCode       String?  @db.NVarChar(50)
  email         String   @db.NVarChar(320)
  recipientKind String   @db.NVarChar(20)
  ownerName     String?  @db.NVarChar(200)
  commitBatchId String?  @db.NVarChar(36)
  sentAt        DateTime @default(now())

  @@index([email])
  @@index([commitBatchId])
  @@map("forecast_notification_send_log")
}

/// User-defined custom columns for registration grid.
model CustomColumnDefinition {
  id              String              @id @default(uuid()) @db.NVarChar(36)
  name            String              @db.NVarChar(200)
  type            String              @db.NVarChar(20)
  dropdownOptions String?             @db.NVarChar(Max)
  defaultValue    String?             @db.NVarChar(500)
  displayOrder    Int                 @default(0)
  isActive        Boolean             @default(true)
  createdBy       String?             @db.NVarChar(200)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  values          CustomColumnValue[]

  @@map("custom_column_definitions")
}

/// Per-registration values for custom columns.
model CustomColumnValue {
  id             Int                    @id @default(autoincrement())
  columnId       String                 @db.NVarChar(36)
  registrationId String                 @db.NVarChar(200)
  value          String?                @db.NVarChar(Max)
  updatedAt      DateTime               @default(now()) @updatedAt
  updatedBy      String?                @db.NVarChar(200)
  column         CustomColumnDefinition @relation(fields: [columnId], references: [id])

  @@unique([columnId, registrationId])
  @@map("custom_column_values")
}

/// App roles for Manage Admin / Manage Email access (keyed by empCode).
model AppUserRole {
  empCode      String   @id @db.NVarChar(50)
  fullNameEng  String   @default("") @db.NVarChar(200)
  currentEmail String   @default("") @db.NVarChar(320)
  role         String   @db.NVarChar(20)
  assignedBy   String?  @db.NVarChar(200)
  source       String   @default("manual") @db.NVarChar(20)
  assignedAt   DateTime @default(now())

  @@index([role])
  @@map("app_user_roles")
}
